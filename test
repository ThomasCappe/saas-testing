#!/usr/bin/env python3
"""
Simple reverse proxy between ansible-galaxy and multiple Artifactory Ansible repos.

Principle
---------
- ansible-galaxy keeps sending its normal paths unchanged
- the proxy does NOT rebuild Galaxy responses
- the proxy only chooses the target Artifactory repo based on the namespace
- then it forwards the original request as-is to the selected repo

Typical use case
----------------
One single URL for clients, multiple backend repos such as:
- internal-ansible-dev
- internal-ansible-prod
- internal-ansible-shared

Routing rule
------------
- if namespace == devops      -> internal-ansible-dev
- if namespace == banking     -> internal-ansible-prod
- if namespace == shared      -> internal-ansible-shared

The proxy keeps the same request path and query string, and only swaps the repo base URL.
"""
from __future__ import annotations

import logging
import os
import re
from dataclasses import dataclass, field
from typing import Dict, Optional
from urllib.parse import urljoin, urlparse

import httpx
import yaml
import json

from fastapi import FastAPI, Header, HTTPException, Request, Response
from fastapi.responses import Response as FastAPIResponse


LOG_LEVEL = os.getenv("LOG_LEVEL", "INFO").upper()
logging.basicConfig(level=LOG_LEVEL, format="%(asctime)s %(levelname)s %(message)s")
logger = logging.getLogger("galaxy-artifactory-namespace-proxy")

DEFAULT_CONFIG_PATH = os.getenv("PROXY_CONFIG", "/etc/ansible-galaxy-proxy.yaml")
DEFAULT_TIMEOUT = int(os.getenv("PROXY_TIMEOUT_SECONDS", "60"))


@dataclass
class RepoConfig:
    name: str
    base_url: str
    token: Optional[str] = None
    verify_tls: bool = True
    timeout_seconds: int = DEFAULT_TIMEOUT


@dataclass
class ProxyConfig:
    repos: Dict[str, RepoConfig] = field(default_factory=dict)
    namespace_to_repo: Dict[str, str] = field(default_factory=dict)
    default_repo: Optional[str] = None



def load_config(path: str = DEFAULT_CONFIG_PATH) -> ProxyConfig:
    with open(path, "r", encoding="utf-8") as fh:
        raw = yaml.safe_load(fh)

    repos: Dict[str, RepoConfig] = {}
    for item in raw.get("repos", []):
        repo = RepoConfig(**item)
        repos[repo.name] = repo

    return ProxyConfig(
        repos=repos,
        namespace_to_repo=raw.get("namespace_to_repo", {}),
        default_repo=raw.get("default_repo"),
    )


CONFIG = load_config()
app = FastAPI(title="Simple Ansible Galaxy -> Artifactory namespace proxy", version="2.0.0")


NAMESPACE_PATTERNS = [
    # /api/v3/plugin/ansible/content/published/collections/index/<namespace>/<name>/...
    re.compile(r"/collections/index/(?P<namespace>[^/]+)/(?P<name>[^/]+)(?:/.*)?$"),
    # /v3/collections/<namespace>/<name>/...
    re.compile(r"/collections/(?P<namespace>[^/]+)/(?P<name>[^/]+)(?:/.*)?$"),
    # /api/v3/plugin/ansible/content/published/collections/artifacts/<namespace>-<name>-<version>.tar.gz
    re.compile(r"/collections/artifacts/(?P<namespace>[^-/]+)-(?P<name>[^/]+)-[^/]+\.tar\.gz$"),
]


def get_proxy_external_base(request: Request) -> str:
    return str(request.base_url).rstrip("/")


def rewrite_json_urls(value, repo: RepoConfig, proxy_base: str):
    if isinstance(value, dict):
        return {k: rewrite_json_urls(v, repo, proxy_base) for k, v in value.items()}
    if isinstance(value, list):
        return [rewrite_json_urls(v, repo, proxy_base) for v in value]
    if isinstance(value, str):
        if value.startswith(repo.base_url):
            rewritten = proxy_base + value[len(repo.base_url):]
            logger.info("rewriting absolute url old=%s new=%s", value, rewritten)
            return rewritten
        parsed = urlparse(value)
        if parsed.scheme in {"http", "https"} and "/artifactory/api/ansible/" in value:
            # Safety net if Artifactory returned a fully qualified ansible repo URL that does not exactly
            # match repo.base_url formatting.
            marker = "/artifactory/api/ansible/"
            idx = value.find(marker)
            if idx >= 0:
                tail = value[idx + len(marker):]
                slash_idx = tail.find("/")
                if slash_idx >= 0:
                    rewritten = proxy_base + "/" + tail[slash_idx + 1 :].lstrip("/")
                    logger.info("rewriting generic ansible repo url old=%s new=%s", value, rewritten)
                    return rewritten
        return value
    return value


@app.get("/api")
@app.get("/api/")
async def api_root_discovery() -> Dict[str, object]:
    return {
        "available_versions": {
            "v3": "v3/"
        }
    }


@app.get("/api/v3")
@app.get("/api/v3/")
async def api_v3_root() -> Dict[str, object]:
    return {
        "available_versions": {
            "v3": "/api/v3/"
        },
        "server_version": app.version,
    }


@app.get("/healthz")
async def healthz() -> Dict[str, str]:
    return {"status": "ok"}


@app.get("/debug/config")
async def debug_config() -> Dict[str, object]:
    return {
        "repos": {
            name: {
                "base_url": repo.base_url,
                "verify_tls": repo.verify_tls,
                "timeout_seconds": repo.timeout_seconds,
                "has_token": bool(repo.token),
            }
            for name, repo in CONFIG.repos.items()
        },
        "namespace_to_repo": CONFIG.namespace_to_repo,
        "default_repo": CONFIG.default_repo,
    }



def extract_namespace(path: str) -> Optional[str]:
    for pattern in NAMESPACE_PATTERNS:
        match = pattern.search(path)
        if match:
            namespace = match.group("namespace")
            logger.info("namespace extracted path=%s namespace=%s pattern=%s", path, namespace, pattern.pattern)
            return namespace
    logger.warning("namespace not extracted path=%s", path)
    return None



def get_repo_for_namespace(namespace: Optional[str]) -> RepoConfig:
    if namespace and namespace in CONFIG.namespace_to_repo:
        repo_name = CONFIG.namespace_to_repo[namespace]
        repo = CONFIG.repos.get(repo_name)
        if not repo:
            logger.error("configured repo missing namespace=%s repo_name=%s", namespace, repo_name)
            raise HTTPException(status_code=500, detail=f"Configured repo not found: {repo_name}")
        logger.info("namespace mapped namespace=%s repo=%s", namespace, repo.name)
        return repo

    if CONFIG.default_repo:
        repo = CONFIG.repos.get(CONFIG.default_repo)
        if not repo:
            logger.error("default repo missing default_repo=%s", CONFIG.default_repo)
            raise HTTPException(status_code=500, detail=f"Default repo not found: {CONFIG.default_repo}")
        logger.warning("namespace fallback namespace=%s default_repo=%s", namespace, repo.name)
        return repo

    logger.error("namespace not mapped namespace=%s", namespace)
    raise HTTPException(status_code=404, detail=f"No repo mapping found for namespace: {namespace}")



def build_upstream_url(repo: RepoConfig, path: str, query_string: bytes) -> str:
    base = repo.base_url.rstrip("/") + "/"
    upstream = urljoin(base, path.lstrip("/"))
    if query_string:
        upstream = f"{upstream}?{query_string.decode()}"
    return upstream



def build_upstream_headers(request: Request, repo: RepoConfig, authorization: Optional[str]) -> Dict[str, str]:
    hop_by_hop_headers = {
        "host",
        "content-length",
        "connection",
        "keep-alive",
        "proxy-authenticate",
        "proxy-authorization",
        "te",
        "trailers",
        "transfer-encoding",
        "upgrade",
        "authorization",
    }

    headers: Dict[str, str] = {}
    for key, value in request.headers.items():
        if key.lower() not in hop_by_hop_headers:
            headers[key] = value

    # Always use the token from the config file for the selected repo.
    if repo.token:
        headers["Authorization"] = f"Bearer {repo.token}"
        logger.info("using configured repo token only repo=%s", repo.name)
    else:
        logger.warning("no configured repo token repo=%s", repo.name)

    return headers


@app.api_route(
    "/{full_path:path}",
    methods=["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"],
)
async def proxy_all(full_path: str, request: Request, authorization: Optional[str] = Header(None)) -> Response:
    path = "/" + full_path
    namespace = extract_namespace(path)
    repo = get_repo_for_namespace(namespace)
    upstream_url = build_upstream_url(repo, path, request.scope.get("query_string", b""))
    headers = build_upstream_headers(request, repo, authorization)
    body = await request.body()

    logger.info(
        "incoming request method=%s namespace=%s repo=%s path=%s query=%s upstream=%s",
        request.method,
        namespace,
        repo.name,
        path,
        request.scope.get("query_string", b"").decode(),
        upstream_url,
    )

    try:
        async with httpx.AsyncClient(timeout=repo.timeout_seconds, verify=repo.verify_tls, follow_redirects=True) as client:
            upstream_response = await client.request(
                method=request.method,
                url=upstream_url,
                headers=headers,
                content=body,
            )
            logger.info(
                "upstream response status=%s repo=%s path=%s content_type=%s",
                upstream_response.status_code,
                repo.name,
                path,
                upstream_response.headers.get("content-type"),
            )
            if upstream_response.status_code >= 400:
                logger.error(
                    "upstream error status=%s repo=%s path=%s body_preview=%s",
                    upstream_response.status_code,
                    repo.name,
                    path,
                    upstream_response.text[:800],
                )
    except httpx.RequestError as exc:
        logger.exception("upstream request error repo=%s path=%s upstream=%s", repo.name, path, upstream_url)
        raise HTTPException(status_code=502, detail=f"Upstream request failed: {exc}") from exc

    response_headers = {
        key: value
        for key, value in upstream_response.headers.items()
        if key.lower() not in {"content-encoding", "transfer-encoding", "connection", "content-length"}
    }

    content_type = upstream_response.headers.get("content-type", "")
    proxy_base = get_proxy_external_base(request)

    if "application/json" in content_type:
        try:
            payload = upstream_response.json()
            rewritten_payload = rewrite_json_urls(payload, repo, proxy_base)
            logger.info("json response rewritten repo=%s path=%s proxy_base=%s", repo.name, path, proxy_base)
            return FastAPIResponse(
                content=json.dumps(rewritten_payload).encode("utf-8"),
                status_code=upstream_response.status_code,
                headers=response_headers,
                media_type="application/json",
            )
        except Exception:
            logger.exception("failed to rewrite json response repo=%s path=%s", repo.name, path)

    return FastAPIResponse(
        content=upstream_response.content,
        status_code=upstream_response.status_code,
        headers=response_headers,
        media_type=upstream_response.headers.get("content-type"),
    )


