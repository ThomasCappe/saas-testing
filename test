@app.get("/api/v3/plugin/ansible/content/published/collections/index/")
async def list_collections(
    request: Request,
    limit: int = Query(100, ge=1, le=1000),
    offset: int = Query(0, ge=0),
    namespace: Optional[str] = Query(None),
    name: Optional[str] = Query(None),
    authorization: Optional[str] = Header(None),
) -> Dict[str, Any]:
    repos = await try_repos_in_priority_order()
    results: List[Dict[str, Any]] = []

    tasks = [get_repo_collections(repo, authorization) for repo in repos]
    per_repo = await asyncio.gather(*tasks, return_exceptions=True)

    for repo, payload in zip(repos, per_repo):
        if isinstance(payload, Exception):
            logger.warning("Failed reading repo %s: %s", repo.name, payload)
            continue
        for item in payload:
            item = dict(item)
            item["_source_repo"] = repo.name
            results.append(item)

    if namespace:
        results = [item for item in results if item.get("namespace") == namespace]
    if name:
        results = [item for item in results if item.get("name") == name]

    results = dedupe_highest(results)
    total = len(results)
    page = results[offset : offset + limit]

    for item in page:
        item["href"] = f"/api/v3/plugin/ansible/content/published/collections/index/{item['namespace']}/{item['name']}/"
        item["versions_url"] = (
            f"/api/v3/plugin/ansible/content/published/collections/index/{item['namespace']}/{item['name']}/versions/"
        )
        if item.get("highest_version", {}).get("version"):
            hv = item["highest_version"]["version"]
            item["highest_version"] = {
                "href": f"/api/v3/plugin/ansible/content/published/collections/index/{item['namespace']}/{item['name']}/versions/{hv}/",
                "version": hv,
            }

    base_path = "/api/v3/plugin/ansible/content/published/collections/index/"
    def link_for(new_offset: Optional[int]) -> Optional[str]:
        if new_offset is None or new_offset < 0 or new_offset >= total:
            return None
        params: Dict[str, Any] = {"limit": limit, "offset": new_offset}
        if namespace:
            params["namespace"] = namespace
        if name:
            params["name"] = name
        return f"{base_path}?{urlencode(params)}"

    return {
        "meta": {"count": total},
        "links": {
            "first": link_for(0),
            "previous": link_for(offset - limit) if offset > 0 else None,
            "next": link_for(offset + limit),
            "last": link_for(max(((total - 1) // limit) * limit, 0)) if total > 0 else None,
        },
        "data": page,
    }


@app.get("/api/v3/plugin/ansible/content/published/collections/index/{namespace}/{name}/")
async def get_collection(
    namespace: str,
    name: str,
    authorization: Optional[str] = Header(None),
) -> Dict[str, Any]:
    repos = await try_repos_in_priority_order()
    candidates: List[Tuple[RepoConfig, Dict[str, Any]]] = []

    for repo in repos:
        try:
            data = await get_repo_collections(repo, authorization)
        except Exception as exc:
            logger.warning("Repo read failed (%s): %s", repo.name, exc)
            continue
        for item in data:
            if item.get("namespace") == namespace and item.get("name") == name:
                candidates.append((repo, item))

    if not candidates:
        raise HTTPException(status_code=404, detail=f"Collection not found: {namespace}.{name}")

    best_repo, best_item = sorted(
        candidates,
        key=lambda pair: semver_key(pair[1].get("highest_version", {}).get("version", "0")),
        reverse=True,
    )[0]

    hv = best_item.get("highest_version", {}).get("version")
    return {
        "href": f"/api/v3/plugin/ansible/content/published/collections/index/{namespace}/{name}/",
        "namespace": namespace,
        "name": name,
        "deprecated": best_item.get("deprecated", False),
        "versions_url": f"/api/v3/plugin/ansible/content/published/collections/index/{namespace}/{name}/versions/",
        "highest_version": {
            "href": f"/api/v3/plugin/ansible/content/published/collections/index/{namespace}/{name}/versions/{hv}/",
            "version": hv,
        } if hv else None,
        "created_at": best_item.get("created_at"),
        "updated_at": best_item.get("updated_at"),
        "repository_context": {"source_repo": best_repo.name},
    }


@app.get("/api/v3/plugin/ansible/content/published/collections/index/{namespace}/{name}/versions/")
async def list_collection_versions(
    namespace: str,
    name: str,
    limit: int = Query(100, ge=1, le=1000),
    offset: int = Query(0, ge=0),
    authorization: Optional[str] = Header(None),
) -> Dict[str, Any]:
    repos = await try_repos_in_priority_order()
    all_versions: List[Dict[str, Any]] = []

    for repo in repos:
        try:
            versions = await get_repo_collection_versions(repo, namespace, name, authorization)
        except Exception as exc:
            logger.debug("Versions not found on repo %s: %s", repo.name, exc)
            continue
        for item in versions:
            v = dict(item)
            v["_source_repo"] = repo.name
            v["href"] = (
                f"/api/v3/plugin/ansible/content/published/collections/index/{namespace}/{name}/versions/{v['version']}/"
            )
            all_versions.append(v)

    if not all_versions:
        raise HTTPException(status_code=404, detail=f"Versions not found: {namespace}.{name}")

    dedup: Dict[str, Dict[str, Any]] = {}
    for item in all_versions:
        dedup[item["version"]] = item

    sorted_versions = sorted(dedup.values(), key=lambda x: semver_key(x["version"]), reverse=True)
    total = len(sorted_versions)
    page = sorted_versions[offset : offset + limit]
    base_path = f"/api/v3/plugin/ansible/content/published/collections/index/{namespace}/{name}/versions/"

    def link_for(new_offset: Optional[int]) -> Optional[str]:
        if new_offset is None or new_offset < 0 or new_offset >= total:
            return None
        return f"{base_path}?{urlencode({'limit': limit, 'offset': new_offset})}"

    return {
        "meta": {"count": total},
        "links": {
            "first": link_for(0),
            "previous": link_for(offset - limit) if offset > 0 else None,
            "next": link_for(offset + limit),
            "last": link_for(max(((total - 1) // limit) * limit, 0)) if total > 0 else None,
        },
        "data": page,
    }


@app.get("/api/v3/plugin/ansible/content/published/collections/index/{namespace}/{name}/versions/{version}/")
async def get_collection_version(
    namespace: str,
    name: str,
    version: str,
    authorization: Optional[str] = Header(None),
) -> Dict[str, Any]:
    repos = await try_repos_in_priority_order()
    for repo in repos:
        try:
            detail = await get_repo_collection_version_detail(repo, namespace, name, version, authorization)
            detail["download_url"] = make_public_url(
                f"/api/v3/plugin/ansible/content/published/collections/artifacts/{namespace}-{name}-{version}.tar.gz?repo={repo.name}&namespace={namespace}&name={name}&version={version}"
            )
            detail["repository_context"] = {"source_repo": repo.name}
            return detail
        except Exception as exc:
            logger.debug("Version detail not found on repo %s: %s", repo.name, exc)
            continue
    raise HTTPException(status_code=404, detail=f"Version not found: {namespace}.{name}:{version}")


@app.get("/api/v3/plugin/ansible/content/published/collections/artifacts/{filename}")
async def download_artifact(
    filename: str,
    repo: str = Query(...),
    namespace: str = Query(...),
    name: str = Query(...),
    version: str = Query(...),
    authorization: Optional[str] = Header(None),
) -> Response:
    repo_cfg = CONFIG.repos.get(repo)
    if not repo_cfg:
        raise HTTPException(status_code=404, detail=f"Unknown repo: {repo}")

    detail = await get_repo_collection_version_detail(repo_cfg, namespace, name, version, authorization)
    upstream_download_url = detail.get("download_url")
    if not upstream_download_url:
        raise HTTPException(status_code=500, detail="No upstream download URL returned")

    headers = normalize_auth_header(authorization, repo_cfg)
    async with httpx.AsyncClient(timeout=repo_cfg.timeout_seconds, verify=repo_cfg.verify_tls) as client:
        upstream = await client.get(upstream_download_url, headers=headers, follow_redirects=True)
        if upstream.status_code >= 400:
            raise HTTPException(status_code=upstream.status_code, detail=upstream.text)
        return StreamingResponse(
            io.BytesIO(upstream.content),
            media_type=upstream.headers.get("content-type", "application/gzip"),
            headers={"Content-Disposition": f'attachment; filename="{filename}"'},
        )


@app.post("/api/v3/artifacts/collections/")
async def upload_collection(
    file: UploadFile = File(...),
    sha256: Optional[str] = Form(None),
    authorization: Optional[str] = Header(None),
) -> Dict[str, Any]:
    file_bytes = await file.read()
    calc_sha256 = hashlib.sha256(file_bytes).hexdigest()
    if sha256 and sha256 != calc_sha256:
        raise HTTPException(status_code=400, detail="sha256 mismatch")

    namespace, name, version = parse_collection_tarball(file_bytes)
    target_repo = route_repo_for_publish(namespace, name)

    logger.info(
        "Publishing %s.%s:%s to repo=%s",
        namespace,
        name,
        version,
        target_repo.name,
    )
    result = await upload_to_repo(
        repo=target_repo,
        tarball=file_bytes,
        filename=file.filename or f"{namespace}-{name}-{version}.tar.gz",
        sha256=calc_sha256,
        authorization=authorization,
    )
    cache.clear()
    return {
        "namespace": namespace,
        "name": name,
        "version": version,
        "target_repo": target_repo.name,
        "upstream_result": result,
    }


