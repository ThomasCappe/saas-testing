#!/usr/bin/env python3
"""
Reverse proxy Galaxy v3 -> multiple Artifactory Ansible repositories.

Goal
----
Expose a single Galaxy-compatible endpoint to ansible-galaxy while routing
reads and writes to multiple Artifactory repos typed as Ansible.

Main features
-------------
- aggregate collection listings across several Artifactory repos
- return Galaxy-like v3 payloads for collection index / versions
- proxy artifact downloads
- route uploads (publish) to a target repo based on namespace/name rules
- simple in-memory cache with TTL
- optional bearer token propagation to Artifactory

Tested design target:
- ansible-galaxy collection install ... -s http://proxy:8080
- ansible-galaxy collection publish ... -s http://proxy:8080 --token=...

Important
---------
Artifactory already supports Ansible repos natively. This proxy is useful
when you want a *single* endpoint in front of multiple repos, or when the
client fails on "list everything" and you want to aggregate / normalize
responses yourself.

Environment variables
---------------------
PROXY_CONFIG=/etc/ansible-galaxy-proxy.yaml
LOG_LEVEL=INFO
CACHE_TTL_SECONDS=60

Example config is at the bottom of this file.
"""
from __future__ import annotations

