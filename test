LOG_LEVEL = os.getenv("LOG_LEVEL", "INFO").upper()
logging.basicConfig(level=LOG_LEVEL, format="%(asctime)s %(levelname)s %(message)s")
logger = logging.getLogger("galaxy-artifactory-proxy")

DEFAULT_CACHE_TTL = int(os.getenv("CACHE_TTL_SECONDS", "60"))
DEFAULT_CONFIG_PATH = os.getenv("PROXY_CONFIG", "/etc/ansible-galaxy-proxy.yaml")
SEMVER_SPLIT_RE = re.compile(r"[^0-9A-Za-z]+")


class TTLCache:
    def __init__(self, ttl_seconds: int = DEFAULT_CACHE_TTL) -> None:
        self.ttl_seconds = ttl_seconds
        self._data: Dict[str, Tuple[float, Any]] = {}

    def get(self, key: str) -> Any | None:
        item = self._data.get(key)
        if not item:
            return None
        expires_at, value = item
        if expires_at < time.time():
            self._data.pop(key, None)
            return None
        return value

    def set(self, key: str, value: Any) -> None:
        self._data[key] = (time.time() + self.ttl_seconds, value)

    def clear(self) -> None:
        self._data.clear()


cache = TTLCache()


@dataclass
class RepoConfig:
    name: str
    base_url: str
    token: Optional[str] = None
    verify_tls: bool = True
    timeout_seconds: int = 30
    read_enabled: bool = True
    write_enabled: bool = False
    priority: int = 100


@dataclass
class RoutingRule:
    repo: str
    namespace_regex: Optional[str] = None
    collection_regex: Optional[str] = None

    def matches(self, namespace: str, collection: str) -> bool:
        ns_ok = True
        col_ok = True
        if self.namespace_regex:
            ns_ok = re.match(self.namespace_regex, namespace) is not None
        if self.collection_regex:
            col_ok = re.match(self.collection_regex, collection) is not None
        return ns_ok and col_ok


@dataclass
class ProxyConfig:
    public_base_url: str
    repos: Dict[str, RepoConfig] = field(default_factory=dict)
    routing_rules: List[RoutingRule] = field(default_factory=list)


def load_config(path: str = DEFAULT_CONFIG_PATH) -> ProxyConfig:
    with open(path, "r", encoding="utf-8") as fh:
        raw = yaml.safe_load(fh)

    repos: Dict[str, RepoConfig] = {}
    for item in raw.get("repos", []):
        repo = RepoConfig(**item)
        repos[repo.name] = repo

    rules = [RoutingRule(**item) for item in raw.get("routing_rules", [])]
    cfg = ProxyConfig(
        public_base_url=raw["public_base_url"].rstrip("/"),
        repos=repos,
        routing_rules=rules,
    )
    return cfg


CONFIG = load_config()
app = FastAPI(title="Ansible Galaxy <-> Artifactory multi-repo proxy", version="1.0.0")


def normalize_auth_header(authorization: Optional[str], repo: RepoConfig) -> Dict[str, str]:
    headers: Dict[str, str] = {"Accept": "application/json"}
    if authorization:
        headers["Authorization"] = authorization
    elif repo.token:
        headers["Authorization"] = f"Bearer {repo.token}"
    return headers


async def fetch_json(client: httpx.AsyncClient, url: str, headers: Dict[str, str]) -> Dict[str, Any]:
    logger.debug("GET %s", url)
    resp = await client.get(url, headers=headers)
    if resp.status_code == 404:
        raise HTTPException(status_code=404, detail=f"Upstream resource not found: {url}")
    resp.raise_for_status()
    return resp.json()


async def upload_to_repo(
    repo: RepoConfig,
    tarball: bytes,
    filename: str,
    sha256: Optional[str],
    authorization: Optional[str],
) -> Dict[str, Any]:
    headers = normalize_auth_header(authorization, repo)
    files = {
        "file": (filename, tarball, "application/gzip"),
    }
    data = {}
    if sha256:
        data["sha256"] = sha256

    upload_url = f"{repo.base_url.rstrip('/')}/api/v3/artifacts/collections/"
    async with httpx.AsyncClient(timeout=repo.timeout_seconds, verify=repo.verify_tls) as client:
        resp = await client.post(upload_url, headers=headers, data=data, files=files)
        if resp.status_code >= 400:
            raise HTTPException(status_code=resp.status_code, detail=resp.text)
        try:
            return resp.json()
        except Exception:
            return {"detail": resp.text, "status_code": resp.status_code}


async def get_repo_collections(repo: RepoConfig, authorization: Optional[str]) -> List[Dict[str, Any]]:
    cache_key = f"collections::{repo.name}::{hashlib.sha256((authorization or '').encode()).hexdigest()}"
    cached = cache.get(cache_key)
    if cached is not None:
        return cached

    url = f"{repo.base_url.rstrip('/')}/api/v3/plugin/ansible/content/published/collections/index/?limit=1000"
    headers = normalize_auth_header(authorization, repo)
    async with httpx.AsyncClient(timeout=repo.timeout_seconds, verify=repo.verify_tls) as client:
        payload = await fetch_json(client, url, headers)
        result = payload.get("data", [])
        cache.set(cache_key, result)
        return result


async def get_repo_collection_versions(
    repo: RepoConfig,
    namespace: str,
    name: str,
    authorization: Optional[str],
) -> List[Dict[str, Any]]:
    cache_key = f"versions::{repo.name}::{namespace}::{name}::{hashlib.sha256((authorization or '').encode()).hexdigest()}"
    cached = cache.get(cache_key)
    if cached is not None:
        return cached

    url = (
        f"{repo.base_url.rstrip('/')}/api/v3/plugin/ansible/content/published/collections/index/"
        f"{namespace}/{name}/versions/?limit=1000"
    )
    headers = normalize_auth_header(authorization, repo)
    async with httpx.AsyncClient(timeout=repo.timeout_seconds, verify=repo.verify_tls) as client:
        payload = await fetch_json(client, url, headers)
        result = payload.get("data", [])
        cache.set(cache_key, result)
        return result


async def get_repo_collection_version_detail(
    repo: RepoConfig,
    namespace: str,
    name: str,
    version: str,
    authorization: Optional[str],
) -> Dict[str, Any]:
    cache_key = (
        f"version-detail::{repo.name}::{namespace}::{name}::{version}::"
        f"{hashlib.sha256((authorization or '').encode()).hexdigest()}"
    )
    cached = cache.get(cache_key)
    if cached is not None:
        return cached

    url = (
        f"{repo.base_url.rstrip('/')}/api/v3/plugin/ansible/content/published/collections/index/"
        f"{namespace}/{name}/versions/{version}/"
    )
    headers = normalize_auth_header(authorization, repo)
    async with httpx.AsyncClient(timeout=repo.timeout_seconds, verify=repo.verify_tls) as client:
        payload = await fetch_json(client, url, headers)
        cache.set(cache_key, payload)
        return payload


async def try_repos_in_priority_order() -> List[RepoConfig]:
    return sorted(
        [repo for repo in CONFIG.repos.values() if repo.read_enabled],
        key=lambda item: item.priority,
    )



def make_public_url(path: str) -> str:
    if not path.startswith("/"):
        path = "/" + path
    return CONFIG.public_base_url + path



def parse_collection_tarball(file_bytes: bytes) -> Tuple[str, str, str]:
    """
    Extract namespace, name, version from MANIFEST.json inside collection tar.gz.
    """
    with tarfile.open(fileobj=io.BytesIO(file_bytes), mode="r:gz") as tar:
        manifest_member = next((m for m in tar.getmembers() if m.name.endswith("MANIFEST.json")), None)
        if not manifest_member:
            raise HTTPException(status_code=400, detail="MANIFEST.json not found in collection tarball")
        manifest_fh = tar.extractfile(manifest_member)
        if manifest_fh is None:
            raise HTTPException(status_code=400, detail="Unable to read MANIFEST.json")
        manifest = json.load(manifest_fh)
        info = manifest.get("collection_info", {})
        namespace = info.get("namespace")
        name = info.get("name")
        version = info.get("version")
        if not all([namespace, name, version]):
            raise HTTPException(status_code=400, detail="namespace/name/version missing in MANIFEST.json")
        return namespace, name, version



def semver_key(version: str) -> Tuple:
    parts = [p for p in SEMVER_SPLIT_RE.split(version) if p != ""]
    normalized: List[Any] = []
    for part in parts:
        if part.isdigit():
            normalized.append((0, int(part)))
        else:
            normalized.append((1, part.lower()))
    return tuple(normalized)



def dedupe_highest(collections: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    merged: Dict[Tuple[str, str], Dict[str, Any]] = {}
    for item in collections:
        key = (item["namespace"], item["name"])
        previous = merged.get(key)
        if previous is None:
            merged[key] = item
            continue
        prev_ver = previous.get("highest_version", {}).get("version", "0")
        curr_ver = item.get("highest_version", {}).get("version", "0")
        if semver_key(curr_ver) > semver_key(prev_ver):
            merged[key] = item
    return sorted(merged.values(), key=lambda x: (x["namespace"], x["name"]))



def route_repo_for_publish(namespace: str, collection: str) -> RepoConfig:
    for rule in CONFIG.routing_rules:
        if rule.matches(namespace, collection):
            repo = CONFIG.repos.get(rule.repo)
            if not repo:
                raise HTTPException(status_code=500, detail=f"Routing rule points to unknown repo: {rule.repo}")
            if not repo.write_enabled:
                raise HTTPException(status_code=403, detail=f"Target repo is not write-enabled: {repo.name}")
            return repo

    write_repos = [repo for repo in CONFIG.repos.values() if repo.write_enabled]
    if len(write_repos) == 1:
        return write_repos[0]
    raise HTTPException(status_code=400, detail="No routing rule matched and no single default write repo exists")


