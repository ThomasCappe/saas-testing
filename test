#!/usr/bin/env python3
from __future__ import annotations

import json
import logging
import os
from dataclasses import dataclass, field
from typing import Dict, Optional, List, Set
from urllib.parse import urljoin, urlparse

import httpx
import yaml
from fastapi import FastAPI, Header, HTTPException, Request, Response
from fastapi.responses import Response as FastAPIResponse


LOG_LEVEL = os.getenv("LOG_LEVEL", "INFO").upper()
logging.basicConfig(level=LOG_LEVEL, format="%(asctime)s %(levelname)s %(message)s")
logger = logging.getLogger("galaxy-multi-repo-proxy")

DEFAULT_CONFIG_PATH = os.getenv("PROXY_CONFIG", "/etc/ansible-galaxy-proxy.yaml")
DEFAULT_TIMEOUT = int(os.getenv("PROXY_TIMEOUT_SECONDS", "60"))


@dataclass
class RepoConfig:
    name: str
    base_url: str
    token: Optional[str] = None
    verify_tls: bool = True
    timeout_seconds: int = DEFAULT_TIMEOUT
    priority: int = 100
    strip_api_prefix: bool = False


@dataclass
class ProxyConfig:
    repos: Dict[str, RepoConfig] = field(default_factory=dict)
    namespace_to_repo: Dict[str, str] = field(default_factory=dict)
    internal_namespaces: Set[str] = field(default_factory=set)
    external_repo_candidates: List[str] = field(default_factory=list)


def load_config(path: str = DEFAULT_CONFIG_PATH) -> ProxyConfig:
    with open(path, "r", encoding="utf-8") as fh:
        raw = yaml.safe_load(fh) or {}

    repos: Dict[str, RepoConfig] = {}
    for item in raw.get("repos", []):
        repo = RepoConfig(**item)
        repos[repo.name] = repo

    return ProxyConfig(
        repos=repos,
        namespace_to_repo=raw.get("namespace_to_repo", {}),
        internal_namespaces=set(raw.get("internal_namespaces", [])),
        external_repo_candidates=raw.get("external_repo_candidates", []),
    )


CONFIG = load_config()
app = FastAPI(title="Ansible Galaxy Multi Repo Proxy", version="8.0.0")


def get_proxy_external_base(request: Request) -> str:
    return str(request.base_url).rstrip("/")


def extract_namespace(path: str) -> Optional[str]:
    logger.info("raw incoming path for namespace extraction=%s", path)

    # 1) Galaxy NG / Automation Hub "index" endpoint
    marker = "/collections/index/"
    if marker in path:
        tail = path.split(marker, 1)[1].strip("/")
        parts = tail.split("/")
        if len(parts) >= 2:
            namespace = parts[0]
            logger.info(
                "namespace extracted from collections index path=%s namespace=%s",
                path,
                namespace,
            )
            return namespace

    # 2) Artifact download endpoint
    marker = "/collections/artifacts/"
    if marker in path:
        filename = path.split(marker, 1)[1].split("/", 1)[0]
        if filename.endswith(".tar.gz") and "-" in filename:
            namespace = filename.split("-", 1)[0]
            logger.info(
                "namespace extracted from artifact filename path=%s namespace=%s filename=%s",
                path,
                namespace,
                filename,
            )
            return namespace

    # 3) Generic collections endpoint
    marker = "/collections/"
    if marker in path:
        tail = path.split(marker, 1)[1].strip("/")
        parts = tail.split("/")
        if len(parts) >= 2 and parts[0] not in {"artifacts", "index"}:
            namespace = parts[0]
            logger.info(
                "namespace extracted from generic collections path=%s namespace=%s",
                path,
                namespace,
            )
            return namespace

    logger.warning("namespace not extracted path=%s", path)
    return None


def ordered_repos() -> List[RepoConfig]:
    return sorted(CONFIG.repos.values(), key=lambda r: r.priority)


def unique_repo_names(names: List[str]) -> List[str]:
    seen = set()
    result = []
    for name in names:
        if name not in seen:
            seen.add(name)
            result.append(name)
    return result


def get_candidate_repos(namespace: Optional[str]) -> List[RepoConfig]:
    ordered = ordered_repos()

    # Internal namespace explicitly mapped
    if namespace and namespace in CONFIG.namespace_to_repo:
        mapped_repo_name = CONFIG.namespace_to_repo[namespace]
        mapped_repo = CONFIG.repos.get(mapped_repo_name)
        if not mapped_repo:
            logger.error("configured repo missing namespace=%s repo_name=%s", namespace, mapped_repo_name)
            raise HTTPException(status_code=500, detail=f"Configured repo not found: {mapped_repo_name}")

        remaining = [repo for repo in ordered if repo.name != mapped_repo.name]
        candidates = [mapped_repo] + remaining
        logger.info(
            "candidate repos for mapped internal namespace namespace=%s repos=%s",
            namespace,
            [repo.name for repo in candidates],
        )
        return candidates

    # Any non-internal namespace goes to Hub repos first
    if namespace and namespace not in CONFIG.internal_namespaces:
        preferred_names = unique_repo_names(CONFIG.external_repo_candidates)
        preferred = [CONFIG.repos[name] for name in preferred_names if name in CONFIG.repos]
        remaining = [repo for repo in ordered if repo.name not in preferred_names]
        candidates = preferred + remaining
        logger.info(
            "candidate repos for non-internal namespace namespace=%s repos=%s",
            namespace,
            [repo.name for repo in candidates],
        )
        return candidates

    # Namespace missing / ambiguous -> try everything by priority
    logger.warning(
        "namespace missing or ambiguous namespace=%s trying all repos by priority=%s",
        namespace,
        [repo.name for repo in ordered],
    )
    return ordered


def build_upstream_url(repo: RepoConfig, path: str, query_string: bytes) -> str:
    upstream_path = path
    base = repo.base_url.rstrip("/") + "/"

    if repo.strip_api_prefix:
        base_parsed = urlparse(repo.base_url)
        base_path = base_parsed.path.rstrip("/")

        # If incoming path already contains the repo path prefix from the Hub,
        # strip it to avoid duplicating it when joining with base_url.
        if base_path and upstream_path.startswith(base_path + "/"):
            upstream_path = upstream_path[len(base_path):]
            upstream_path = "/" + upstream_path.lstrip("/")

        # Fallback: if path starts with /api/, strip only that prefix for Hub-like repos
        elif upstream_path.startswith("/api/"):
            upstream_path = upstream_path[len("/api/"):]
            upstream_path = "/" + upstream_path.lstrip("/")

    upstream = urljoin(base, upstream_path.lstrip("/"))

    if query_string:
        upstream = f"{upstream}?{query_string.decode()}"

    return upstream


def build_upstream_headers(request: Request, repo: RepoConfig) -> Dict[str, str]:
    hop_by_hop_headers = {
        "host",
        "content-length",
        "connection",
        "keep-alive",
        "proxy-authenticate",
        "proxy-authorization",
        "te",
        "trailers",
        "transfer-encoding",
        "upgrade",
        "authorization",
    }

    headers: Dict[str, str] = {}
    for key, value in request.headers.items():
        if key.lower() not in hop_by_hop_headers:
            headers[key] = value

    # Use only token from config
    if repo.token:
        headers["Authorization"] = f"Bearer {repo.token}"
        logger.info("using configured repo token only repo=%s", repo.name)
    else:
        logger.warning("no configured repo token repo=%s", repo.name)

    return headers


def rewrite_single_url(value: str, repo: RepoConfig, proxy_base: str) -> str:
    parsed = urlparse(value)

    if value.startswith(repo.base_url):
        rewritten = proxy_base + value[len(repo.base_url):]
        logger.info("rewriting repo-base url old=%s new=%s", value, rewritten)
        return rewritten

    if parsed.scheme in {"http", "https"} and "/artifactory/api/ansible/" in parsed.path:
        marker = "/artifactory/api/ansible/"
        tail = parsed.path.split(marker, 1)[1]
        slash_idx = tail.find("/")
        if slash_idx >= 0:
            rewritten_path = "/" + tail[slash_idx + 1:].lstrip("/")
            rewritten = proxy_base + rewritten_path
            if parsed.query:
                rewritten += f"?{parsed.query}"
            logger.info("rewriting artifactory ansible url old=%s new=%s", value, rewritten)
            return rewritten

    if parsed.scheme in {"http", "https"} and "/api/v3/plugin/ansible/content/published/collections/artifacts/" in parsed.path:
        rewritten = proxy_base + parsed.path
        if parsed.query:
            rewritten += f"?{parsed.query}"
        logger.info("rewriting direct artifact url old=%s new=%s", value, rewritten)
        return rewritten

    return value


def rewrite_json_urls(value, repo: RepoConfig, proxy_base: str):
    special_url_keys = {"download_url", "href", "versions_url", "first", "previous", "next", "last"}

    if isinstance(value, dict):
        new_dict = {}
        for k, v in value.items():
            if k in special_url_keys and isinstance(v, str):
                new_v = rewrite_single_url(v, repo, proxy_base)
                if new_v != v:
                    logger.info("rewriting json field key=%s old=%s new=%s", k, v, new_v)
                new_dict[k] = new_v
            else:
                new_dict[k] = rewrite_json_urls(v, repo, proxy_base)
        return new_dict

    if isinstance(value, list):
        return [rewrite_json_urls(v, repo, proxy_base) for v in value]

    if isinstance(value, str):
        return rewrite_single_url(value, repo, proxy_base)

    return value


@app.get("/api")
@app.get("/api/")
async def api_root_discovery() -> Dict[str, object]:
    return {"available_versions": {"v3": "v3/"}}


@app.get("/api/v3")
@app.get("/api/v3/")
async def api_v3_root() -> Dict[str, object]:
    return {
        "available_versions": {"v3": "/api/v3/"},
        "server_version": app.version,
    }


@app.get("/healthz")
async def healthz() -> Dict[str, str]:
    return {"status": "ok"}


@app.get("/debug/config")
async def debug_config() -> Dict[str, object]:
    return {
        "repos": {
            name: {
                "base_url": repo.base_url,
                "verify_tls": repo.verify_tls,
                "timeout_seconds": repo.timeout_seconds,
                "priority": repo.priority,
                "strip_api_prefix": repo.strip_api_prefix,
                "has_token": bool(repo.token),
            }
            for name, repo in CONFIG.repos.items()
        },
        "namespace_to_repo": CONFIG.namespace_to_repo,
        "internal_namespaces": sorted(CONFIG.internal_namespaces),
        "external_repo_candidates": CONFIG.external_repo_candidates,
    }


@app.api_route(
    "/{full_path:path}",
    methods=["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"],
)
async def proxy_all(full_path: str, request: Request, authorization: Optional[str] = Header(None)) -> Response:
    path = "/" + full_path
    namespace = extract_namespace(path)
    candidate_repos = get_candidate_repos(namespace)
    body = await request.body()

    last_response = None
    last_repo = None

    # Retry on those statuses before giving answer back to ansible-galaxy
    retryable_statuses = {403, 404, 502, 503}

    for repo in candidate_repos:
        upstream_url = build_upstream_url(repo, path, request.scope.get("query_string", b""))
        headers = build_upstream_headers(request, repo)

        logger.info(
            "incoming request method=%s namespace=%s repo=%s path=%s query=%s upstream=%s",
            request.method,
            namespace,
            repo.name,
            path,
            request.scope.get("query_string", b"").decode(),
            upstream_url,
        )

        try:
            async with httpx.AsyncClient(
                timeout=repo.timeout_seconds,
                verify=repo.verify_tls,
                follow_redirects=True,
            ) as client:
                upstream_response = await client.request(
                    method=request.method,
                    url=upstream_url,
                    headers=headers,
                    content=body,
                )
                logger.info(
                    "upstream response status=%s repo=%s path=%s content_type=%s",
                    upstream_response.status_code,
                    repo.name,
                    path,
                    upstream_response.headers.get("content-type"),
                )
                if upstream_response.status_code >= 400:
                    logger.error(
                        "upstream error status=%s repo=%s path=%s body_preview=%s",
                        upstream_response.status_code,
                        repo.name,
                        path,
                        upstream_response.text[:800],
                    )
        except httpx.RequestError:
            logger.exception("upstream request error repo=%s path=%s upstream=%s", repo.name, path, upstream_url)
            continue

        last_response = upstream_response
        last_repo = repo

        if upstream_response.status_code not in retryable_statuses:
            break

        logger.warning(
            "repo returned retryable status=%s, trying next repo repo=%s path=%s",
            upstream_response.status_code,
            repo.name,
            path,
        )

    if last_response is None or last_repo is None:
        raise HTTPException(status_code=502, detail="All upstream repos failed to respond")

    response_headers = {
        key: value
        for key, value in last_response.headers.items()
        if key.lower() not in {"content-encoding", "transfer-encoding", "connection", "content-length"}
    }

    content_type = last_response.headers.get("content-type", "")
    proxy_base = get_proxy_external_base(request)

    if "application/json" in content_type:
        try:
            payload = last_response.json()
            rewritten_payload = rewrite_json_urls(payload, last_repo, proxy_base)
            logger.info("json response rewritten repo=%s path=%s proxy_base=%s", last_repo.name, path, proxy_base)
            return FastAPIResponse(
                content=json.dumps(rewritten_payload).encode("utf-8"),
                status_code=last_response.status_code,
                headers=response_headers,
                media_type="application/json",
            )
        except Exception:
            logger.exception("failed to rewrite json response repo=%s path=%s", last_repo.name, path)

    return FastAPIResponse(
        content=last_response.content,
        status_code=last_response.status_code,
        headers=response_headers,
        media_type=last_response.headers.get("content-type"),
    )