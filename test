#     timeout_seconds: 60
#
#   - name: internal-shared
#     base_url: "https://jfrog.example.com/artifactory/api/ansible/internal-ansible-shared"
#     token: null
#     verify_tls: true
#     timeout_seconds: 60
#
# namespace_to_repo:
#   devops: internal-dev
#   sandbox: internal-dev
#   banking: internal-prod
#   core: internal-prod
